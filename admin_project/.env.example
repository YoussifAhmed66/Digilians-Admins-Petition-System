# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Admin Petitions API
APP_ENV=production

SECRET_KEY=your_secret_key_here

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ATTACHMENTS_BUCKET=attachments
SUPABASE_GENERATED_BUCKET=generated

# ── Templates ────────────────────────────────────────────────────────────────
DOCX_TEMPLATE_PATH=docs/external.docx

# ── Uploads ──────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_COUNT=5
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ── Timezone ─────────────────────────────────────────────────────────────────
TIMEZONE=Africa/Cairo

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL (comma-separated for multiple)
# Example: ALLOWED_ORIGINS=https://admin-petitions.vercel.app
ALLOWED_ORIGINS=*
